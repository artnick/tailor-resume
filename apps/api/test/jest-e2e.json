{
  "preset": "ts-jest",
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testMatch": ["<rootDir>/test/**/*.e2e-spec.ts"],
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@repo/shared$": "<rootDir>/../../packages/shared/src/index.ts",
    "^@repo/renderer$": "<rootDir>/../../packages/renderer/src/index.ts",
    "^puppeteer$": "<rootDir>/test/__mocks__/puppeteer.ts",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": [
      "@swc/jest",
      {
        "jsc": {
          "parser": {
            "syntax": "typescript",
            "decorators": true
          },
          "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
          },
          "target": "es2022"
        },
        "module": {
          "type": "commonjs"
        }
      }
    ]
  }
}
